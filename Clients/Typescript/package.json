{
  "name": "goplay-ws",
  "version": "0.9.0",
  "description": "Websocket client for GoPlay.Net (https://github.com/jennal/goplay.net)",
  "main": "dist/goplay.js",
  "types": "dist/goplay.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); fs.copyFileSync('src/pkg.pb.js','dist/pkg.pb.js'); fs.copyFileSync('src/pkg.pb.d.ts','dist/pkg.pb.d.ts');\"",
    "build:bundle": "webpack",
    "test": "jest",
    "test:e2e": "bash scripts/test.sh",
    "release": "bash scripts/publish.sh",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jennal/goplay.net.git",
    "directory": "Clients/Typescript"
  },
  "homepage": "https://github.com/jennal/goplay.net#readme",
  "bugs": {
    "url": "https://github.com/jennal/goplay.net/issues"
  },
  "keywords": [
    "goplay",
    "websocket",
    "ws",
    "protobuf",
    "game",
    "rpc",
    "client"
  ],
  "author": "Jennal",
  "license": "MIT",
  "dependencies": {
    "google-protobuf": "^3.21.2",
    "long": "^5.2.3",
    "protobufjs": "^7.2.5",
    "ws": "^8.14.1"
  },
  "devDependencies": {
    "@babel/core": "^7.22.19",
    "@babel/preset-env": "^7.22.15",
    "@babel/preset-typescript": "^7.22.15",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.4",
    "@types/ws": "^8.5.5",
    "babel-loader": "^9.1.3",
    "exports-loader": "^4.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.0",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  }
}
