{
    "compilerOptions": {
        "target": "ES2017",
        "module": "CommonJS",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "lib": ["DOM", "ES2017"],
        "baseUrl": ".",
        "paths": {
            "*": ["./src/*"]
        },
        "noImplicitAny": false,
        "removeComments": true,
        "preserveConstEnums": true,
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "skipLibCheck": true,
        "outDir": "./dist"
    },
    "include": ["src/*.ts"],
    "exclude": [
        "node_modules/**/*",
        "unit_test/**/*",
        "dist/**/*"
    ]
}
